# 13. SUMMARY TABLE FOR MANUSCRIPT
# ----------------------------------------------------------------------------
summary_data = {
    "Metric": [
        "Posterior median OR",
        "95% Credible Interval",
        "Pr(OR < 1.0) – any protective effect",
        "Pr(OR < 0.77) – ≥23% RRR",
        "Pr(OR < 0.60) – ≥40% RRR",
        "Pr(OR in ROPE 0.95–1.05) – primary",
        "Pr(OR below ROPE) – primary",
        "Pr(OR in ROPE 0.90–1.10) – sensitivity",
        "Pr(OR in ROPE 0.85–1.15) – sensitivity",
        "Expected utility threshold (Cost/Benefit)",
        "Sensitivity range (Pr(OR < 1.0))"
    ],
    "Value": [
        f"{post_median_OR:.3f}",
        f"{cr_lower:.3f} – {cr_upper:.3f}",
        f"{prob_OR_lt_1:.1%}",
        f"{prob_OR_lt_077:.1%}",
        f"{prob_OR_lt_060:.1%}",
        f"{prob_in_rope_primary:.1%}",
        f"{prob_below_rope_primary:.1%}",
        f"{df_rope_sens[df_rope_sens['ROPE'] == 'Wider (10%)']['Pr(within ROPE)'].values[0]:.1%}",
        f"{df_rope_sens[df_rope_sens['ROPE'] == 'Widest (15%)']['Pr(within ROPE)'].values[0]:.1%}",
        f"{threshold_ratio:.1f}",
        f"{df_sens['Pr(OR<1.0)'].min():.1%} – {df_sens['Pr(OR<1.0)'].max():.1%}"
    ]
}
df_summary = pd.DataFrame(summary_data)

print("\n" + "=" * 80)
print("SUMMARY TABLE FOR MANUSCRIPT")
print("=" * 80)
print(df_summary.to_string(index=False))
print("=" * 80)

print("\nAll figures saved successfully:")
print("  - Figure1_Prior_Posterior_ROPE.png")
